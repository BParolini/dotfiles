{
    "editor.fontFamily": "Iosevka",
    "editor.fontSize": 15.0,
    "editor.ligatures": true,
    "editor.lineSpacing": 1.2,
    "terminal.lineSpacing": 1.0,
    "ff.autoSyncEditors": true,
    "ff.showShortcutsInGotoPanel": true,
    "files.exclude": [".DS_Store", ".git", "Thumbs.db", ".idea", ".gradle", ".uuid", ".directory", "desktop.ini"],
    "keymap": "macos-ij",
    "rename.autoRenameOnTyping": true,
    "terminal.enableFocusEditorOnEsc": true,
    "files.openFileMode": "doubleClick",
    "files.keyboardNavigation": "Highlight",
    "editor.honorCamelHumps": true,
    "theme": "dark",
    "restoreWorkspacesOnStartup": false,
    "editor.softWrapEnabled": true,
    "terminal.fontSize": 15.0,
    "editor.distractionFreeMode": false,
    "editor.previewTab": false
}